{
    "name": "members/project-scaffold",
    "type": "wordpress-project",
    "description": "",
    "homepage": "https://github.com/a8cteam51/ChargeBee-to-WP-Importer",
    "license": "GPL-2.0-or-later",
    "authors": [{
        "name": "Contributors",
        "homepage": "https://github.com/a8cteam51/ChargeBee-to-WP-Importer/graphs/contributors"
    }],
    "repositories": [{
            "type": "vcs",
            "url": "https://github.com/a8cteam51/team51-configs"
        },
        {
            "type": "composer",
            "url": "https://wpackagist.org",
            "only": [
                "wpackagist-plugin/*",
                "wpackagist-theme/*"
            ]
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-json": "*"
    },
    "require-dev": {
        "a8cteam51/team51-configs": "dev-trunk",
        "wp-cli/i18n-command": "^2.6",
        "roave/security-advisories": "dev-latest",
        "guzzlehttp/guzzle": ">=6.5",
        "symfony/var-dumper": "5.*"
    },
    "scripts": {
        "format:php": "phpcbf --standard=.phpcs.xml --basepath=. ./mu-plugins/members-peopleofprint-importer -v",
        "lint:php": [
            "@lint:php:chargebee-import:phpcs",
            "@lint:php:chargebee-import:phpmd",
            "@lint:php:chargebee-import:phpstan"
        ],
        "lint:php:chargebee-import:phpcs": "phpcs --standard=.phpcs.xml --basepath=. --ignore=chargebee/** . -v",
        "lint:php:chargebee-import:phpmd": "phpmd . ansi .phpmd.xml --exclude=chargebee/** -v",
        "lint:php:chargebee-import:phpstan": "phpstan analyse -c .phpstan.neon  -v --memory-limit=10G",
        "packages-install": "@composer install --ignore-platform-reqs --no-interaction",
        "packages-update": [
            "@composer clear-cache",
            "@composer update --prefer-stable --ignore-platform-reqs --no-interaction"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/*": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "installer-paths": {
            "plugins/{$name}/": [
                "type:wordpress-plugin"
            ],
            "themes/{$name}/": [
                "type:wordpress-theme"
            ]
        }
    }
}